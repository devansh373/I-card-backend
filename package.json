{
  "name": "i-card-print-project",
  "version": "1.0.0",
  "description": "---",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon --watch src --exec node --loader ts-node/esm src/server.ts",
    "build": "prisma generate && tsc",
    "start": "node dist/server.js",
    "start:prod": "NODE_ENV=production node dist/server.js",
    "docker:dev": "docker-compose -f docker-compose.dev.yml up",
    "docker:dev:build": "docker-compose -f docker-compose.dev.yml up --build",
    "docker:dev:down": "docker-compose -f docker-compose.dev.yml down",
    "docker:dev:stop": "docker-compose -f docker-compose.dev.yml stop",
    "docker:dev:logs": "docker-compose -f docker-compose.dev.yml logs -f",
    "docker:dev:logs:backend": "docker-compose -f docker-compose.dev.yml logs -f backend-dev",
    "docker:dev:logs:postgres": "docker-compose -f docker-compose.dev.yml logs -f postgres-dev",
    "docker:dev:rebuild": "docker-compose -f docker-compose.dev.yml up -d --build --force-recreate",
    "docker:up": "docker-compose up",
    "docker:build": "docker-compose up --build -d",
    "docker:down": "docker-compose down",
    "docker:stop": "docker-compose stop",
    "docker:restart": "docker-compose restart",
    "docker:logs": "docker-compose logs -f",
    "docker:logs:backend": "docker-compose logs -f backend",
    "docker:logs:postgres": "docker-compose logs -f postgres",
    "docker:rebuild": "docker-compose up -d --build --force-recreate",
    "docker:prod": "docker-compose -f docker-compose.prod.yml up -d",
    "docker:prod:build": "docker-compose -f docker-compose.prod.yml up --build -d",
    "docker:prod:down": "docker-compose -f docker-compose.prod.yml down",
    "docker:prod:stop": "docker-compose -f docker-compose.prod.yml stop",
    "docker:prod:restart": "docker-compose -f docker-compose.prod.yml restart",
    "docker:prod:logs": "docker-compose -f docker-compose.prod.yml logs -f",
    "docker:prod:logs:backend": "docker-compose -f docker-compose.prod.yml logs -f backend",
    "docker:prod:logs:postgres": "docker-compose -f docker-compose.prod.yml logs -f postgres",
    "docker:prod:rebuild": "docker-compose -f docker-compose.prod.yml up -d --build --force-recreate",
    "docker:clean": "docker-compose down -v --remove-orphans",
    "docker:clean:all": "docker-compose down -v --remove-orphans --rmi all && docker-compose -f docker-compose.dev.yml down -v --remove-orphans --rmi all && docker-compose -f docker-compose.prod.yml down -v --remove-orphans --rmi all",
    "docker:clean:dev": "docker-compose -f docker-compose.dev.yml down -v --remove-orphans",
    "docker:clean:prod": "docker-compose -f docker-compose.prod.yml down -v --remove-orphans",
    "docker:ps": "docker-compose ps"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/adapter-pg": "^7.2.0",
    "@prisma/client": "^7.2.0",
    "bcrypt": "^6.0.0",
    "canvas": "^3.2.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "imagekit": "^6.0.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.0.2",
    "node-fetch": "^3.3.2",
    "nodemailer": "^7.0.12",
    "papaparse": "^5.5.3",
    "pdfkit": "^0.17.2",
    "pg": "^8.16.3",
    "prisma": "^7.2.0",
    "resend": "^6.7.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.0.3",
    "@types/nodemailer": "^7.0.4",
    "@types/papaparse": "^5.5.2",
    "@types/pdfkit": "^0.17.4",
    "@types/pg": "^8.16.0",
    "nodemon": "^3.1.11",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}