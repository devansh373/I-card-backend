# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5438/school_id

# Server Configuration
PORT=5000
NODE_ENV=development

# Authentication
# IMPORTANT: Generate a strong random secret for production (at least 32 characters)
# You can generate one using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Admin Credentials (for initial setup)
# IMPORTANT: Change these before deploying to production
ADMIN_EMAIL=admin@vendor.com
ADMIN_PASSWORD=your-secure-admin-password-here

# ImageKit Configuration (Global - Optional if using per-school config)
# Get these from https://imagekit.io/dashboard
IMAGEKIT_PUBLIC_KEY=your_imagekit_public_key
IMAGEKIT_PRIVATE_KEY=your_imagekit_private_key
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_imagekit_id

# Email Configuration (Optional - for sending credentials)
# Get API key from https://resend.com
RESEND_API_KEY=your_resend_api_key

# CORS Configuration (Optional - defaults to localhost in development)
# Comma-separated list of allowed origins
# Example: https://yourdomain.com,https://app.yourdomain.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Production Notes:
# 1. Never commit this file with real credentials to version control
# 2. Use strong, randomly generated values for JWT_SECRET and ADMIN_PASSWORD
# 3. Set NODE_ENV=production in production environments
# 4. Configure ALLOWED_ORIGINS to only include your production domains
# 5. Use environment-specific .env files (.env.production, .env.staging, etc.)
